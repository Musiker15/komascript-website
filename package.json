{
  "name": "komascript-homepage",
  "version": "1.0.0",
  "private": true,
  "description": "Offizielle Homepage für KOMA-Script — vielseitige LaTeX-Klassen und Pakete",
  "license": "MIT",
  "author": "Markus Kohm",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "next build --turbopack",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mdx,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mdx,css}\"",
    "validate:content": "tsx scripts/validate-content.ts",
    "build:search": "tsx scripts/build-search-index.ts",
    "test": "vitest --passWithNoTests",
    "test:e2e": "playwright test",
    "prebuild": "pnpm run validate:content && pnpm run build:search"
  },
  "dependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "next-intl": "^4.0.0",
    "next-themes": "^0.4.4",
    "next-mdx-remote": "^6.0.0",
    "@fontsource-variable/inter": "^5.1.1",
    "@fontsource-variable/jetbrains-mono": "^5.1.2",
    "gray-matter": "^4.0.3",
    "zod": "^3.23.8",
    "lucide-react": "^0.469.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.5",
    "remark-gfm": "^4.0.0",
    "remark-toc": "^9.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.0",
    "shiki": "^1.24.0",
    "flexsearch": "^0.7.43",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-navigation-menu": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@radix-ui/react-slot": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/mdx": "^2.0.13",
    "typescript": "^5.7.2",
    "eslint": "^9.17.0",
    "typescript-eslint": "^8.61.0",
    "@eslint/js": "^9.17.0",
    "@tailwindcss/postcss": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.15",
    "postcss": "^8.4.49",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.19.2",
    "vitest": "^4.1.0",
    "@playwright/test": "^1.60.0"
  }
}
