# =============================================================================
# KOMA-Script Homepage: Beispiel-Environment
# -----------------------------------------------------------------------------
# Diese Datei dokumentiert alle Variablen. Lokal: nach `.env.local` kopieren.
# Server: nach `/opt/komascript/.env.production` legen (gitignored).
# =============================================================================

# Öffentliche Basis-URL der Seite (ohne trailing Slash)
NEXT_PUBLIC_SITE_URL=https://komascript.musiker15.de

# Telemetrie deaktivieren (empfohlen)
NEXT_TELEMETRY_DISABLED=1

# Node-Modus
NODE_ENV=production

# Port, lokal 3000 für Entwicklung
# Server: systemd-Unit überschreibt auf 3100 (siehe deploy/systemd/komascript.service)
PORT=3000
